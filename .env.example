# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase migrations (recommended for production deploys)
# Used by `npm run migrate` (runs during `npm run build` on Vercel) to apply files in `supabase/migrations`.
# Provide either a direct DB URL, or Supabase CLI credentials.
#
# Option A: direct DB URL (preferred if available)
# POSTGRES_URL_NON_POOLING=postgresql://...
#
# Option B: Supabase CLI credentials
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=xtmvbhybdncggegbbvuq
# SUPABASE_DB_PASSWORD=

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (required for notifications)
RESEND_API_KEY=re_...

# AI Assistant (required for chatbot)
ANTHROPIC_API_KEY=sk-ant-...
# Portal chatbot: daily token budget per user (input+output, successful chat only). Staff/super_admin/admin are unlimited.
# AI_CHATBOT_DAILY_TOKEN_LIMIT=60000
# Optional override for the message shown when the token limit is hit (plain text).
# AI_CHATBOT_LIMIT_MESSAGE=

# OAuth Integrations (calendar + file storage sync)
# Google Calendar (Integrations / Settings "Connect" flow)
# Create OAuth client in Google Cloud Console (APIs & Services > Credentials).
# Authorized redirect URI must match exactly:
#   {NEXT_PUBLIC_APP_URL}/api/integrations/google/callback
# Enable "Google Calendar API" for the project. Scopes are requested by the app (calendar + email).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# Microsoft Outlook / 365 calendar
# Register app in Azure Entra ID. Redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/integrations/microsoft/callback
# Supported account types: include personal Microsoft accounts if needed ("common").
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
#
# Dropbox (File storage sync)
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
#
# HMAC secret for OAuth `state` (calendar/file flows). Required in production; do not reuse service role key.
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# AWS S3 (secure destination storage)
# Option 1: Set env vars below. Option 2: Admin > Integrations stores credentials encrypted (requires ENCRYPTION_SECRET).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Encryption for admin-stored secrets (S3 credentials in app_settings)
# SECURITY: Must be at least 32 characters for production use
# Generate with: openssl rand -base64 32
# NEVER commit this value to git or expose to client code
ENCRYPTION_SECRET=

# SMS & WhatsApp (optional - Twilio)
TWILIO_ACCOUNT_SID=ACxxxx...
TWILIO_AUTH_TOKEN=xxxx...
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# App Configuration
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Kre8ivTech portal):
# NEXT_PUBLIC_APP_URL=https://clients.kre8ivtech.com
NODE_ENV=development

# White-label: optional comma-separated hostnames treated as valid CNAME targets for domain verification
# (defaults to hostname of NEXT_PUBLIC_APP_URL). Add Vercel's target if different, e.g.:
# WHITE_LABEL_CNAME_TARGETS=cname.vercel-dns.com
WHITE_LABEL_CNAME_TARGETS=

# Cron / Vercel Cron: Bearer token for `/api/cron/*` routes (required in production).
# If unset, only super_admin/admin session (manual trigger) can run crons.
# Generate with: openssl rand -hex 32
CRON_SECRET=
